DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# File Upload Settings
# Path tempat menyimpan uploaded files (absolute path recommended untuk production)
# Development: "./uploads"
# Production: "/var/www/uploads"
UPLOADS_DIR="./uploads"

MAX_FILE_SIZE="10485760" # 10MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/jpg,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# Supabase (optional, jika pakai supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
